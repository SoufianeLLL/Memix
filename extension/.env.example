# Development-only overrides for local extension work.
# Production marketplace installs should not require any of these.
MEMIX_DEV_EXTERNAL_DAEMON= # default: false
MEMIX_DAEMON_HTTP_URL= # default: http://127.0.0.1:3456
MEMIX_PORT= # default: 3456
MEMIX_DAEMON_MANIFEST_URL= # default: https://api.memix.dev/daemon/manifest.json
