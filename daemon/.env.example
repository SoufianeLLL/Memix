# Logging level
RUST_LOG=info
# error → only errors (safe for production)
# warn  → warnings + errors
# info  → normal operation logs
# debug → development (high volume)

# Set this to true when using external daemon mode (dev only)
MEMIX_DEV_EXTERNAL_DAEMON=true

# The Workspace Root Folder
MEMIX_WORKSPACE_ROOT=

# Set this to match your extension's project when using external daemon mode (dev only)
MEMIX_PROJECT_ID= 

# Team sync / licensing
# Optional override for the bundled public verification key.
# Production builds should use the committed public key in daemon/keys/memix_public.der by default.
MEMIX_LICENSE_PUBLIC_KEY=
# Base64-encoded Ed25519 PKCS8 private key used by optional local issuer/service flows only.
# Do not use or ship this in the public extension/daemon runtime.
MEMIX_LICENSE_PRIVATE_KEY=
# Optional license service base URL used for revocation / subscription status checks.
# Example: https://api.memix.dev
MEMIX_LICENSE_SERVER_URL=
# Optional checkout URL used by the local/dev initiate flow.
# Example: https://checkout.memix.dev/pay
MEMIX_LICENSE_CHECKOUT_URL=

# Skeleton Index Safeguards
MEMIX_MAX_FUNCTIONS_PER_FILE=50       # Prevents bloat from generated files
MEMIX_MAX_TYPES_PER_FILE=30           # Same
MEMIX_MAX_IMPORTS_PER_FILE=20         # Caps import list rendering
MEMIX_MAX_DEPS_PER_FILE=20            # Caps dependency list
MEMIX_MAX_HOT_FILES=30                # Bounds FuSI to active dev frontier
MEMIX_MAX_SYMBOLS_PER_HOT_FILE=50     # Caps FuSI entries per file
MEMIX_MAX_SKELETON_ENTRIES=2,000      # Redis budget for all skeletons
MEMIX_FSI_DEBOUNCE_SECS=1             # Prevents save-spamming
MEMIX_REINDEX_RATE_LIMIT=10     # Max reindex attempts per check

# OXC Semantic Analysis
MEMIX_OXC_ENABLED=true                # Uses OXC compiler-grade parser for Javascript/Typescript files
MEMIX_OXC_RESOLVE_NODE_MODULES=false  # Set to true to track imports crossing into `node_modules` (expensive)
MEMIX_OXC_MAX_RESOLVE_DEPTH=10        # Maximum depth algorithm recurses looking for module resolution

# Petgraph / Importance Algorithms
MEMIX_IMPORTANCE_CACHE_TTL_SECS=60     # Future-proof TTL for graph-metric caching
MEMIX_MAX_BLAST_RADIUS_DEPTH=5        # Prevents infinite loops running blast radius graph recursion
