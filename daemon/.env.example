# Logging level
RUST_LOG=info
# error → only errors (safe for production)
# warn  → warnings + errors
# info  → normal operation logs
# debug → development (high volume)

# Team sync / licensing
# Optional override for the bundled public verification key.
# Production builds should use the committed public key in daemon/keys/memix_public.der by default.
MEMIX_LICENSE_PUBLIC_KEY=
# Base64-encoded Ed25519 PKCS8 private key used by optional local issuer/service flows only.
# Do not use or ship this in the public extension/daemon runtime.
MEMIX_LICENSE_PRIVATE_KEY=
# Optional license service base URL used for revocation / subscription status checks.
# Example: https://api.memix.dev
MEMIX_LICENSE_SERVER_URL=
# Optional checkout URL used by the local/dev initiate flow.
# Example: https://checkout.memix.dev/pay
MEMIX_LICENSE_CHECKOUT_URL=
