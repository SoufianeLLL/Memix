{
	"name": "memix",
	"displayName": "memix",
	"description": "Persistent memory for AI coding assistants. Never re-explain your project again.",
	"version": "0.1.0",
	"publisher": "digitalvizellc",
	"engines": {
		"vscode": "^1.107.0"
	},
	"categories": [
		"AI",
		"Other"
	],
	"keywords": [
		"ai",
		"memory",
		"cursor",
		"windsurf",
		"antigravity",
		"openai",
		"claude",
		"copilot",
		"context"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/SoufianeLLL/Memix"
	},
	"icon": "media/icon.png",
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "memix.init",
				"title": "Memix: Initialize Brain"
			},
			{
				"command": "memix.connect",
				"title": "Memix: Connect Redis"
			},
			{
				"command": "memix.disconnect",
				"title": "Memix: Disconnect Redis"
			},
			{
				"command": "memix.showPanel",
				"title": "Memix: Open Debug Panel"
			},
			{
				"command": "memix.exportBrain",
				"title": "Memix: Export Brain"
			},
			{
				"command": "memix.importBrain",
				"title": "Memix: Import Brain"
			},
			{
				"command": "memix.healthCheck",
				"title": "Memix: Health Check"
			},
			{
				"command": "memix.prune",
				"title": "Memix: Prune Brain"
			},
			{
				"command": "memix.clearBrain",
				"title": "Memix: Clear Brain"
			},
			{
				"command": "memix.teamSync",
				"title": "Memix: Team Sync Setup"
			},
			{
				"command": "memix.recoverBrain",
				"title": "Memix: Recover Corrupted Brain"
			},
			{
				"command": "memix.endSession",
				"title": "Memix: End Session"
			},
			{
				"command": "memix.clearSecrets",
				"title": "Memix: Clear Stored Secrets"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "memix-sidebar",
					"title": "Memix",
					"icon": "media/icon.png"
				}
			]
		},
		"views": {
			"memix-sidebar": [
				{
					"icon": "media/icon.png",
					"type": "webview",
					"id": "memix.debugPanel",
					"name": "Brain Monitor"
				}
			]
		},
		"configuration": {
			"title": "Memix",
			"properties": {
				"memix.projectId": {
					"type": "string",
					"default": "",
					"description": "Project identifier (auto-detected from folder name if empty)"
				},
				"memix.maxBrainSizeKB": {
					"type": "number",
					"default": 512,
					"description": "Maximum brain size in KB before auto-pruning"
				},
				"memix.maxTokenBudget": {
					"type": "number",
					"default": 4000,
					"description": "Max tokens to inject into AI context"
				},
				"memix.autoSave": {
					"type": "boolean",
					"default": true,
					"description": "Automatically save brain state"
				},
				"memix.autoGenerateRules": {
					"type": "boolean",
					"default": true,
					"description": "Auto-generate AI rules files on project open"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/crypto-js": "^4.2.2",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/uuid": "^10.0.0",
		"@types/vscode": "^1.107.0",
		"@vscode/test-cli": "^0.0.11",
		"@vscode/test-electron": "^2.5.2",
		"eslint": "^9.39.3",
		"ts-loader": "^9.5.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"webpack": "^5.105.3",
		"webpack-cli": "^6.0.1"
	},
	"dependencies": {
		"crypto-js": "^4.2.0",
		"ioredis": "^5.10.0",
		"uuid": "^13.0.0"
	}
}